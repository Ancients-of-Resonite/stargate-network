{
  "tasks": {
    "dev": "deno run --watch --allow-env --allow-net src/main.ts",
    "db:migrate": "deno -A --env --node-modules-dir npm:drizzle-kit migrate",
    "db:pull": "deno -A --env --node-modules-dir npm:drizzle-kit pull",
    "db:push": "deno -A --env --node-modules-dir npm:drizzle-kit push",
    "db:generate": "deno -A --env --node-modules-dir npm:drizzle-kit generate",
    "db:studio": "deno -A --env --node-modules-dir npm:drizzle-kit studio"
  },
  "imports": {
    "@/": "./src/",
    "@std/assert": "jsr:@std/assert@1",
    "@types/pg": "npm:@types/pg@^8.15.5",
    "drizzle-kit": "npm:drizzle-kit@^0.31.4",
    "drizzle-orm": "npm:drizzle-orm@^0.44.5",
    "pg": "npm:pg@^8.16.3",
    "pocketbase": "npm:pocketbase@0.21.2",
    "colors": "https://deno.land/std@0.117.0/fmt/colors.ts"
  }
}
